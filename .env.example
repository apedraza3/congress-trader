SECRET_KEY=change-me-to-random-string
AUTH_PASSWORD=admin

# Alpaca (paper trading)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Data sources (FMP is primary, Finnhub is fallback)
FMP_API_KEY=
FINNHUB_API_KEY=

# App settings
DB_PATH=data/congress.db
FLASK_PORT=5051
POLL_INTERVAL_HOURS=2

# Risk filters
MAX_REPORTING_DELAY_DAYS=3
MIN_TRADE_AMOUNT=15000
MAX_PRICE_CHANGE_PCT=5.0
MIN_POLITICIAN_WIN_RATE=60.0
MAX_POSITION_PCT=5.0
STOP_LOSS_PCT=8.0
HOLD_DAYS=45
MAX_OPEN_POSITIONS=15

# Technical analysis
REQUIRE_TECHNICAL_CONFIRMATION=true

# Recession guard (FRED Sahm Rule)
ENABLE_RECESSION_GUARD=true

# AI sentiment (local Ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
ENABLE_AI_SENTIMENT=true
